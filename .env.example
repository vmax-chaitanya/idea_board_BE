NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/idea_board?schema=public
# Vercel/serverless Postgres: use your host's pooler URL, sslmode=require, and connect_timeout so bad DB config fails fast (e.g. ?sslmode=require&connect_timeout=10)
OPENAI_API_KEY=
AI_PROVIDER=mock
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# Optional: comma-separated browser origins (omit to allow any origin via reflected CORS)
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173
