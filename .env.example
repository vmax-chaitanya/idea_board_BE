NODE_ENV=development
PORT=4000
# Optional: only needed for `prisma migrate` / Studio against Postgres (not used at runtime if you use Supabase below)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/idea_board?schema=public
# Runtime API (Vercel): Supabase JS — use service role on the server only
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
# If you copied vars from a Next.js app, these are also accepted:
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...  (not used by this Express API; browser/RLS only)
OPENAI_API_KEY=
AI_PROVIDER=mock
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# Optional: comma-separated browser origins (omit to allow any origin via reflected CORS)
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173
