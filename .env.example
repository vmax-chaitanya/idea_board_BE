NODE_ENV=development
PORT=4000
# Optional: only needed for Prisma migration/studio workflows
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/idea_board?schema=public
# Runtime API: Supabase JS — use service role on the server only
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
# Optional: cap each Supabase HTTP call (ms)
# SUPABASE_FETCH_TIMEOUT_MS=8000
OPENAI_API_KEY=
AI_PROVIDER=mock
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# Optional: comma-separated browser origins (omit to allow any origin via reflected CORS)
# CORS_ORIGINS=http://localhost:5173
